{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "maxwellmezadre/construbase",
    "type": "project",
    "description": "Construbase - Laravel 12.x and Filament 5.x",
    "keywords": [
        "laravel-starter-kit",
        "starter-kit",
        "filament-starter-kit",
        "laravel",
        "filament",
        "filament-v5",
        "livewire",
        "tailwindcss"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "achyutn/filament-log-viewer": "^2.1",
        "bezhansalleh/filament-shield": "^4.1",
        "dutchcodingcompany/filament-developer-logins": "^2.1",
        "filament/filament": "^5.0",
        "jeffersongoncalves/filament-logo": "^3.0",
        "joaopaulolndev/filament-edit-profile": "^3.0",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^3.0.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.0",
        "barryvdh/laravel-ide-helper": "^3.5",
        "driftingly/rector-laravel": "^2.1",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.2",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan icons:cache"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --tag=livewire:assets --ansi --force",
            "@php artisan filament:upgrade",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "ide-helper": [
            "@php artisan ide-helper:generate -q",
            "@php artisan ide-helper:meta -q",
            "@php artisan ide-helper:model --write --reset -q -n",
            "./vendor/bin/pint --config=pint.json -q"
        ],
        "pint": [
            "./vendor/bin/pint --config=pint.json -q"
        ],
        "phpstan": [
            "./vendor/bin/phpstan"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "schedule": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd\" \"php artisan schedule:work\" --names=schedule"
        ],
        "queue": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd\" \"php artisan queue:listen --tries=1\" --names=queue"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "ext-pcntl": "7.1",
            "ext-posix": "7.1"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
